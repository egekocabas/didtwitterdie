{
  "name": "didtwitterdie",
  "description": "A data dashboard tracking the popularity of twitter.com vs x.com since the July 2023 rebrand",
  "version": "1.0.0",
  "author": "Ege Kocabas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/egekocabas/didtwitterdie"
  },
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*.ts",
    "#functions/*": "./functions/*.ts"
  },
  "scripts": {
    "dev": "vite",
    "dev:mobile": "npm run dev -- --host",
    "dev:full": "npm run build && wrangler pages dev dist",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/**/*.test.ts",
    "lint": "eslint . --max-warnings=0",
    "preview": "wrangler pages dev dist",
    "deploy": "wrangler pages deploy dist"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.2",
    "framer-motion": "12.42.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.0",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260629.1",
    "@eslint/js": "9.39.4",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.0",
    "wrangler": "4.105.0"
  }
}
